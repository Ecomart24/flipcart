{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo Skip install prebuilt static bundle",
  "buildCommand": "echo Use committed artifacts/api-server/public",
  "outputDirectory": "artifacts/api-server/public",
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
